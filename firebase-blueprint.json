{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "lawyer", "assistant", "client"] },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Case": {
      "title": "Legal Case",
      "description": "Information about a legal case file.",
      "type": "object",
      "properties": {
        "caseNumber": { "type": "string" },
        "clientName": { "type": "string" },
        "opposingParty": { "type": "string" },
        "jurisdiction": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed", "pending", "archived"] },
        "assignedLawyerId": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "documents": {
          "type": "array",
          "items": { "$ref": "Document" }
        }
      },
      "required": ["caseNumber", "clientName", "status"]
    },
    "Task": {
      "title": "Task",
      "description": "A task assigned to a user, optionally linked to a case.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedUserId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "isPersonal": { "type": "boolean" }
      },
      "required": ["title", "assignedUserId", "status"]
    },
    "Event": {
      "title": "Calendar Event",
      "description": "An event in the legal calendar.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["hearing", "meeting", "deadline", "other"] },
        "assignedUserIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "startTime", "endTime", "type"]
    },
    "Message": {
      "title": "Collaboration Message",
      "description": "A message in a global or private chat.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "readBy": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["chatId", "authorId", "content", "timestamp", "readBy"]
    },
    "Document": {
      "title": "Case Document",
      "description": "Metadata for a document uploaded to a case.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["caseId", "name", "url", "uploadedBy"]
    },
    "Invoice": {
      "title": "Billing Invoice",
      "description": "Information about a billing invoice for a client.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "clientId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid", "cancelled", "partial"] },
        "dueDate": { "type": "string", "format": "date" },
        "issueDate": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "payments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "amount": { "type": "number" },
              "date": { "type": "string", "format": "date" },
              "method": { "type": "string", "enum": ["cash", "transfer", "card", "other"] },
              "reference": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "amount", "status", "issueDate"]
    },
    "SACSummary": {
      "title": "SAC Summary",
      "description": "AI-generated summary of SAC updates.",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "caseNumber": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["decreto", "expediente", "novedad"] },
        "importantDeadlines": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "rawText": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "date", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/cases/{caseId}": {
      "schema": "Case",
      "description": "Legal case files."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks and deadlines."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Calendar events."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collaboration messages."
    },
    "/documents/{documentId}": {
      "schema": "Document",
      "description": "Case document metadata."
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Billing invoices and payments."
    },
    "/sac_summaries/{summaryId}": {
      "schema": "SACSummary",
      "description": "AI-generated summaries of SAC updates."
    }
  }
}
