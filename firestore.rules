rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Custom Auth Collections
    match /credentials/{credId} {
      allow read: if true;
      allow write: if true;
    }
    match /admin_config/{configId} {
      allow read: if true;
      allow write: if true;
    }

    // App Collections
    // Since the app uses a custom auth system without Firebase Auth, 
    // we must allow read/write access for now. 
    // WARNING: This is insecure and should be replaced with Firebase Auth.
    match /users/{userId} {
      allow read, write: if true;
    }
    match /cases/{caseId} {
      allow read, write: if true;
    }
    match /messages/{messageId} {
      allow read, write: if true;
    }
    match /tasks/{taskId} {
      allow read, write: if true;
    }
    match /events/{eventId} {
      allow read, write: if true;
    }
    match /documents/{documentId} {
      allow read, write: if true;
    }
    match /invoices/{invoiceId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
